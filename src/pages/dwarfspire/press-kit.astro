---
import BaseHead from '../../components/BaseHead.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Dwarfspire | Coldfront Games" description="Dwarfspire — an indie game by Coldfront Games. Wishlist now on Steam." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@700;900&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
	</head>
	<body>

		<!-- ── Navigation ── -->
		<header id="site-header">
			<div class="site-wrap header-inner">
				<a href="/" class="logo">
					<img src="/logo_white.svg" alt="" class="logo-img" aria-hidden="true" />
					<span data-i18n="site-title">COLDFRONT GAMES</span>
				</a>
				<nav class="main-nav" aria-label="Main navigation">
					<a href="/#studio">Studio</a>
					<a href="/dwarfspire/press-kit" aria-current="page">Dwarfspire</a>
				</nav>
				<div class="header-right">
					<button class="lang-toggle" id="lang-toggle" aria-label="Switch language">
						<span class="lang-opt" data-lang="en">EN</span>
						<span class="lang-sep">/</span>
						<span class="lang-opt" data-lang="fr">FR</span>
					</button>
					<div class="social-links">
						<a href="https://x.com/JeuxColdfront" aria-label="X" target="_blank" rel="noopener noreferrer">
							<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
						</a>
						<a href="https://www.tiktok.com/@coldfrontgames" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
							<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
						</a>
						<a href="https://discord.gg/j3dtdpmEur" aria-label="Discord" target="_blank" rel="noopener noreferrer">
							<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.031.053a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
						</a>
						<a href="https://www.youtube.com/channel/UCHjoBBM9Mv_VCVwZvLUE5Wg" aria-label="YouTube" target="_blank" rel="noopener noreferrer">
							<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
						</a>
						<a href="https://www.instagram.com/coldfrontgames/" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
							<svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z"/></svg>
						</a>
					</div>
					<button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
						<span></span><span></span><span></span>
					</button>
				</div>
			</div>
		</header>

		<!-- ── Mobile Menu ── -->
		<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
			<nav>
				<a href="/#studio" class="mobile-link">Studio</a>
				<a href="/dwarfspire/press-kit" class="mobile-link">Dwarfspire</a>
			</nav>
			<button class="lang-toggle lang-toggle-mobile" id="lang-toggle-mobile" aria-label="Switch language">
				<span class="lang-opt" data-lang="en">EN</span>
				<span class="lang-sep">/</span>
				<span class="lang-opt" data-lang="fr">FR</span>
			</button>
		</div>

		<main>

			<!-- ── 1. Trailer ── -->
			<section class="trailer-section">
				<div class="site-wrap trailer-wrap">
					<div class="video-frame">
						<iframe
							src="https://www.youtube.com/embed/JKdH01J6Qwg"
							title="Dwarfspire — Official Trailer"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							allowfullscreen
						></iframe>
					</div>
				</div>
			</section>

			<!-- ── 2. Wishlist ── -->
			<section class="wishlist-section">
				<div class="site-wrap wishlist-inner">
					<h2 class="wishlist-heading" data-i18n="wishlist-heading">Wishlist Now</h2>
					<a href="https://store.steampowered.com/app/4375040/Dwarfspire/" target="_blank" rel="noopener noreferrer" class="steam-btn">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.492 1.009 2.447-.397.957-1.494 1.411-2.455 1.02zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"/></svg>
						<span data-i18n="steam-btn">Wishlist on Steam</span>
					</a>
				</div>
			</section>

			<!-- ── 3. Description + Screenshots ── -->
			<section class="details-section">
				<div class="site-wrap">
					<div class="description">
						<p class="desc-lead" data-i18n="desc-lead">DWARFSPIRE is an idle crafting game that sits on the side of your screen.</p>
						<p data-i18n="desc-p1">Manage a village of rock-climbing dwarves as they go on perilous expeditions up the mountainside in search of rare gems and minerals. Use your gathered resources to craft weapons and armor to trade to a wide variety of customers.</p>
						<p data-i18n="desc-p2">DWARFSPIRE stays on top of your desktop, allowing you to do other things while your dwarves are hard at work.</p>
						<p class="desc-tagline" data-i18n="desc-tagline">In this idle crafting desktop game they rise while you grind.</p>
					</div>
					<div class="screenshot-grid">
						<img src="/dwarfspire/Screenshots/Screenshot_1.png" alt="Dwarfspire screenshot 1" />
						<img src="/dwarfspire/Screenshots/Screenshot_2.png" alt="Dwarfspire screenshot 2" />
						<img src="/dwarfspire/Screenshots/Screenshot_3.png" alt="Dwarfspire screenshot 3" />
						<img src="/dwarfspire/Screenshots/Screenshot_4.png" alt="Dwarfspire screenshot 4" />
						<img src="/dwarfspire/Screenshots/Screenshot_5.png" alt="Dwarfspire screenshot 5" />
						<img src="/dwarfspire/Screenshots/Screenshot_6.png" alt="Dwarfspire screenshot 6" />
						<img src="/dwarfspire/Screenshots/Screenshot_7.png" alt="Dwarfspire screenshot 7" />
						<img src="/dwarfspire/Screenshots/Screenshot_8.png" alt="Dwarfspire screenshot 8" />
					</div>
				</div>
			</section>

		</main>

		<!-- ── Lightbox ── -->
		<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Screenshot viewer">
			<button class="lightbox-close" id="lightbox-close" aria-label="Close">&times;</button>
			<button class="lightbox-prev" id="lightbox-prev" aria-label="Previous">&#8249;</button>
			<img class="lightbox-img" id="lightbox-img" src="" alt="" />
			<button class="lightbox-next" id="lightbox-next" aria-label="Next">&#8250;</button>
			<span class="lightbox-counter" id="lightbox-counter"></span>
		</div>

		<!-- ── Footer ── -->
		<footer>
			<div class="site-wrap footer-inner">
				<span class="footer-logo" data-i18n="site-title">COLDFRONT GAMES</span>
				<span class="footer-loc" data-i18n="footer-loc">Somewhere cold.</span>
			</div>
		</footer>

	</body>
</html>

<script>
	const hamburger = document.getElementById('hamburger');
	const mobileMenu = document.getElementById('mobile-menu');

	hamburger?.addEventListener('click', () => {
		const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
		hamburger.setAttribute('aria-expanded', String(!isOpen));
		hamburger.classList.toggle('open', !isOpen);
		mobileMenu?.classList.toggle('open', !isOpen);
		mobileMenu?.setAttribute('aria-hidden', String(isOpen));
	});

	document.querySelectorAll('.mobile-link').forEach(link => {
		link.addEventListener('click', () => {
			hamburger?.setAttribute('aria-expanded', 'false');
			hamburger?.classList.remove('open');
			mobileMenu?.classList.remove('open');
			mobileMenu?.setAttribute('aria-hidden', 'true');
		});
	});

	window.addEventListener('scroll', () => {
		document.getElementById('site-header')?.classList.toggle('scrolled', window.scrollY > 10);
	}, { passive: true });

	// ── Language toggle ──
	const translations: Record<string, { en: string; fr: string }> = {
		'site-title':      { en: 'COLDFRONT GAMES',  fr: 'JEUX COLDFRONT' },
		'wishlist-heading':{ en: 'Wishlist Now',      fr: 'Ajouter aux souhaits' },
		'steam-btn':       { en: 'Wishlist on Steam', fr: 'Liste de souhaits Steam' },
		'desc-lead':       {
			en: 'DWARFSPIRE is an idle crafting game that sits on the side of your screen.',
			fr: 'DWARFSPIRE est un jeu de craft idle qui se glisse sur le côté de votre écran.',
		},
		'desc-p1': {
			en: 'Manage a village of rock-climbing dwarves as they go on perilous expeditions up the mountainside in search of rare gems and minerals. Use your gathered resources to craft weapons and armor to trade to a wide variety of customers.',
			fr: 'Gérez un village de nains grimpeurs qui partent en périlleuses expéditions sur la montagne à la recherche de gemmes et de minéraux rares. Utilisez vos ressources pour fabriquer des armes et des armures à vendre à une grande variété de clients.',
		},
		'desc-p2': {
			en: 'DWARFSPIRE stays on top of your desktop, allowing you to do other things while your dwarves are hard at work.',
			fr: 'DWARFSPIRE reste au premier plan de votre bureau, vous permettant de vaquer à vos occupations pendant que vos nains travaillent dur.',
		},
		'desc-tagline': {
			en: 'In this idle crafting desktop game they rise while you grind.',
			fr: 'Dans ce jeu de craft idle sur bureau, ils grimpent pendant que vous progressez.',
		},
		'footer-loc': { en: 'Somewhere cold.', fr: 'Quelque part dans le froid.' },
	};

	let currentLang: 'en' | 'fr' = (localStorage.getItem('cf-lang') as 'en' | 'fr') || 'en';

	function applyLang(lang: 'en' | 'fr') {
		currentLang = lang;
		localStorage.setItem('cf-lang', lang);
		document.documentElement.lang = lang;

		document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
			const key = el.dataset.i18n!;
			if (translations[key]) el.textContent = translations[key][lang];
		});

		document.querySelectorAll<HTMLElement>('.lang-opt').forEach(opt => {
			opt.classList.toggle('active', opt.dataset.lang === lang);
		});
	}

	function handleLangToggle() { applyLang(currentLang === 'en' ? 'fr' : 'en'); }

	document.getElementById('lang-toggle')?.addEventListener('click', handleLangToggle);
	document.getElementById('lang-toggle-mobile')?.addEventListener('click', handleLangToggle);

	applyLang(currentLang);

	// ── Lightbox ──
	const screenshots = Array.from(document.querySelectorAll<HTMLImageElement>('.screenshot-grid img'));
	const lightbox    = document.getElementById('lightbox')!;
	const lbImg       = document.getElementById('lightbox-img') as HTMLImageElement;
	const lbCounter   = document.getElementById('lightbox-counter')!;
	let current       = 0;

	function openLightbox(index: number) {
		current = index;
		lbImg.src = screenshots[current].src;
		lbImg.alt = screenshots[current].alt;
		lbCounter.textContent = `${current + 1} / ${screenshots.length}`;
		lightbox.classList.add('open');
		document.body.style.overflow = 'hidden';
	}

	function closeLightbox() {
		lightbox.classList.remove('open');
		document.body.style.overflow = '';
	}

	function showPrev() {
		openLightbox((current - 1 + screenshots.length) % screenshots.length);
	}

	function showNext() {
		openLightbox((current + 1) % screenshots.length);
	}

	screenshots.forEach((img, i) => img.addEventListener('click', () => openLightbox(i)));

	document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
	document.getElementById('lightbox-prev')?.addEventListener('click', showPrev);
	document.getElementById('lightbox-next')?.addEventListener('click', showNext);

	lightbox.addEventListener('click', (e) => {
		if (e.target === lightbox) closeLightbox();
	});

	document.addEventListener('keydown', (e) => {
		if (!lightbox.classList.contains('open')) return;
		if (e.key === 'Escape')      closeLightbox();
		if (e.key === 'ArrowLeft')   showPrev();
		if (e.key === 'ArrowRight')  showNext();
	});
</script>

<style>
	:root {
		--white:    #ffffff;
		--sky:      #6fc4ef;
		--blue:     #1c80cb;
		--mid-blue: #367cc1;
		--navy:     #033b8c;
		--deep:     #133454;
		--bg:       var(--white);
		--bg-alt:   #eef5fb;
		--ink:      var(--deep);
		--ink-mid:  var(--mid-blue);
		--border:   rgba(54, 124, 193, 0.18);
		--nav-h:    68px;
		--wrap:     1400px;
		--pad:      4vw;
	}

	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
	html { scroll-behavior: smooth; }

	body {
		background: var(--bg);
		color: var(--ink);
		font-family: 'DM Sans', sans-serif;
		font-size: 17px;
		line-height: 1.7;
		overflow-x: hidden;
		animation: pageIn 0.65s ease 0.1s both;
	}

	@keyframes pageIn { from { opacity: 0; } to { opacity: 1; } }

	.site-wrap {
		width: 100%;
		max-width: var(--wrap);
		margin: 0 auto;
		padding-left: var(--pad);
		padding-right: var(--pad);
	}

	main { width: 100%; max-width: 100%; padding: 0; margin: 0; }

	/* ── Header ── */
	#site-header {
		position: fixed;
		top: 0; left: 0; right: 0;
		z-index: 200;
		height: var(--nav-h);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		background: linear-gradient(to bottom, rgba(19, 52, 84, 0.75) 0%, rgba(19, 52, 84, 0) 100%);
		border-bottom: 1px solid transparent;
		transition: border-color 0.3s, background 0.3s;
		--header-ink: var(--white);
	}

	#site-header.scrolled {
		border-bottom-color: var(--border);
		background: rgba(255, 255, 255, 0.96);
		--header-ink: var(--deep);
	}

	.header-inner {
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: 'Barlow', sans-serif;
		font-weight: 700;
		font-size: 1rem;
		letter-spacing: 0.18em;
		color: var(--header-ink);
		text-decoration: none;
		white-space: nowrap;
		flex-shrink: 0;
		transition: color 0.3s;
	}

	.logo-img {
		height: 38px;
		width: auto;
		display: block;
		flex-shrink: 0;
		transition: filter 0.3s;
	}

	#site-header.scrolled .logo-img {
		filter: brightness(0) saturate(0);
	}

	.main-nav { display: flex; align-items: center; gap: 2.5rem; }

	.main-nav a {
		font-family: 'DM Sans', sans-serif;
		font-size: 0.875rem;
		font-weight: 400;
		letter-spacing: 0.06em;
		color: var(--header-ink);
		text-decoration: none;
		text-transform: uppercase;
		transition: opacity 0.2s;
		opacity: 0.75;
	}

	.main-nav a:hover,
	.main-nav a[aria-current="page"] { opacity: 1; }

	.header-right { display: flex; align-items: center; gap: 1.25rem; flex-shrink: 0; }

	.social-links { display: flex; align-items: center; gap: 0.9rem; }

	.social-links a {
		color: var(--header-ink);
		opacity: 0.55;
		display: flex;
		align-items: center;
		text-decoration: none;
		transition: color 0.3s, opacity 0.2s;
	}

	.social-links a:hover { opacity: 1; }

	/* ── Lang toggle ── */
	.lang-toggle {
		display: flex;
		align-items: center;
		gap: 0.2rem;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.25rem 0.4rem;
