---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="snowflakes" aria-hidden="true">
			<span class="flake">❄</span>
			<span class="flake">❄</span>
			<span class="flake">❄</span>
			<span class="flake">❄</span>
			<span class="flake">❄</span>
			<span class="flake">❄</span>
			<span class="flake">❄</span>
		</div>

		<main>
			<div class="crystal">✦</div>
			<h1>
				<span class="cold">COLDFRONT</span>
				<span class="games">GAMES</span>
			</h1>
			<div class="divider"></div>
			<p class="coming-soon">Coming Soon<span class="cursor">_</span></p>
			<p class="tagline">An indie game studio is forming in the cold.</p>
		</main>
	</body>
</html>

<style>
	:root {
		--bg: #07091a;
		--ice: #a8d8f0;
		--white: #f0f4ff;
		--dim: #4a5a7a;
		--glow: #5ab4e0;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html, body {
		height: 100%;
	}

	body {
		background-color: var(--bg);
		background-image:
			radial-gradient(ellipse at 20% 50%, rgba(30, 60, 120, 0.3) 0%, transparent 60%),
			radial-gradient(ellipse at 80% 20%, rgba(20, 80, 140, 0.2) 0%, transparent 50%);
		color: var(--white);
		font-family: "Atkinson", system-ui, sans-serif;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		overflow: hidden;
		position: relative;
	}

	main {
		text-align: center;
		padding: 2rem;
		position: relative;
		z-index: 1;
	}

	.crystal {
		font-size: 2.5rem;
		color: var(--ice);
		opacity: 0.7;
		display: block;
		margin-bottom: 1.5rem;
		animation: spin 20s linear infinite;
	}

	h1 {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.1em;
		line-height: 1;
		margin-bottom: 1.5rem;
	}

	.cold {
		font-size: clamp(3rem, 12vw, 7rem);
		font-weight: 700;
		letter-spacing: 0.15em;
		color: var(--white);
		text-shadow:
			0 0 40px rgba(90, 180, 224, 0.4),
			0 0 80px rgba(90, 180, 224, 0.15);
	}

	.games {
		font-size: clamp(1.1rem, 4vw, 2.2rem);
		font-weight: 400;
		letter-spacing: 0.6em;
		color: var(--ice);
		padding-left: 0.6em; /* optical centering for letter-spacing */
	}

	.divider {
		width: 60px;
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--glow), transparent);
		margin: 0 auto 1.75rem;
	}

	.coming-soon {
		font-size: clamp(1rem, 3vw, 1.4rem);
		font-weight: 700;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		color: var(--white);
		padding-left: 0.35em;
	}

	.cursor {
		animation: blink 1.1s step-end infinite;
		color: var(--ice);
	}

	.tagline {
		margin-top: 1.25rem;
		font-size: clamp(0.8rem, 2vw, 0.95rem);
		color: var(--dim);
		letter-spacing: 0.05em;
		font-style: italic;
	}

	/* Drifting snowflakes */
	.snowflakes {
		position: fixed;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}

	.flake {
		position: absolute;
		top: -2em;
		color: var(--ice);
		opacity: 0;
		font-size: 1rem;
		animation: drift linear infinite;
		user-select: none;
	}

	.flake:nth-child(1)  { left:  8%; font-size: 0.7rem; animation-duration: 14s; animation-delay:  0s; }
	.flake:nth-child(2)  { left: 21%; font-size: 1.1rem; animation-duration: 18s; animation-delay:  3s; }
	.flake:nth-child(3)  { left: 37%; font-size: 0.6rem; animation-duration: 12s; animation-delay:  7s; }
	.flake:nth-child(4)  { left: 52%; font-size: 0.9rem; animation-duration: 16s; animation-delay:  1s; }
	.flake:nth-child(5)  { left: 65%; font-size: 0.7rem; animation-duration: 20s; animation-delay:  5s; }
	.flake:nth-child(6)  { left: 78%; font-size: 1.2rem; animation-duration: 15s; animation-delay:  9s; }
	.flake:nth-child(7)  { left: 91%; font-size: 0.8rem; animation-duration: 13s; animation-delay:  2s; }

	@keyframes drift {
		0%   { transform: translateY(0)    rotate(0deg);   opacity: 0; }
		10%  { opacity: 0.5; }
		90%  { opacity: 0.2; }
		100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
	}

	@keyframes spin {
		from { transform: rotate(0deg); }
		to   { transform: rotate(360deg); }
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50%       { opacity: 0; }
	}
</style>
